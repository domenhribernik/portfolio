# Canonical host: https://domenhribernik.com (no www). Every rule is anchored
# to the production host so local XAMPP is never redirected.
<IfModule mod_rewrite.c>
RewriteEngine On

# www -> apex
RewriteCond %{HTTP_HOST} ^www\.domenhribernik\.com$ [NC]
RewriteRule ^ https://domenhribernik.com%{REQUEST_URI} [R=301,L]

# http -> https on the apex (X-Forwarded-Proto guard for a fronting proxy)
RewriteCond %{HTTP_HOST} ^domenhribernik\.com$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://domenhribernik.com%{REQUEST_URI} [R=301,L]

# Legacy blog reader URLs -> static per-post pages
RewriteCond %{HTTP_HOST} ^(www\.)?domenhribernik\.com$ [NC]
RewriteCond %{QUERY_STRING} (?:^|&)slug=([A-Za-z0-9-]+)
RewriteRule ^views/blog/post\.html$ /views/blog/%1/? [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 0 seconds"
ExpiresByType text/css "access plus 7 days"
ExpiresByType application/javascript "access plus 7 days"
ExpiresByType image/png "access plus 30 days"
ExpiresByType image/jpeg "access plus 30 days"
ExpiresByType image/x-icon "access plus 30 days"
</IfModule>
